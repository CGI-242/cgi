{
  "expo": {
    "name": "CGI242 - Intelligence Fiscale IA",
    "slug": "cgi-242",
    "version": "1.0.0",
    "description": "Application mobile du Code General des Impots du Congo (edition 2026). Consultation des 7 000+ articles, simulateurs fiscaux (ITS, IS, Patente) et echeances fiscales.",
    "owner": "normxai",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "cgi242",
    "newArchEnabled": true,
    "githubUrl": "https://github.com/normxai/cgi-242",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#00815d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.normxai.cgi242",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Utilisé pour la recherche vocale",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00815d"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.normxai.cgi242",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "jsEngine": "jsc"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "@sentry/react-native",
      "expo-speech-recognition",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00815d"
        }
      ],
      "expo-localization",
      "expo-screen-capture"
    ],
    "extra": {
      "privacyUrl": "https://cgi242.normx.ai/confidentialite",
      "termsUrl": "https://cgi242.normx.ai/conditions",
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "assetBundlePatterns": [
      "**/*"
    ]
  }
}
