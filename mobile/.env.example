# =============================================================================
# CGI-242 Mobile — Variables d'environnement
# =============================================================================
# Copier ce fichier en .env et remplir les valeurs
#   cp .env.example .env
# =============================================================================

# URL de l'API backend (obligatoire)
# - Developpement : http://localhost:3003/api
# - Production    : https://api.cgi242.normx.ai/api
EXPO_PUBLIC_API_URL=http://localhost:3003/api

# Sentry DSN pour le monitoring d'erreurs (optionnel)
# - Creer un projet sur https://sentry.io
# - Copier le DSN depuis : Settings > Projects > cgi-242 > Client Keys (DSN)
# - Si vide, Sentry est desactive (pas de monitoring d'erreurs)
EXPO_PUBLIC_SENTRY_DSN=
